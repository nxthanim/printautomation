#!/bin/bash
set -euo pipefail

APP_DIR=/opt/print-automation
VENV_DIR=$APP_DIR/venv
DB_NAME=printautomation
DB_USER=printuser
DB_PASS=$(openssl rand -base64 24)
STORAGE_DIRS="$APP_DIR/storage/pdfs $APP_DIR/storage/receipts"

case "$1" in
    configure)
        echo "Configuring Print Automation Server..."

        if ! id -u printauto &>/dev/null; then
            useradd --system --no-create-home --home-dir "$APP_DIR" printauto
            echo "Created system user: printauto"
        fi

        mkdir -p $STORAGE_DIRS
        chown -R printauto:printauto "$APP_DIR/storage"
        echo "Storage directories created: $STORAGE_DIRS"

        if command -v psql &>/dev/null; then
            su - postgres -c "psql -tc \"SELECT 1 FROM pg_roles WHERE rolname='$DB_USER'\" | grep -q 1" 2>/dev/null || \
                su - postgres -c "psql -c \"CREATE USER $DB_USER WITH PASSWORD '$DB_PASS';\"" 2>/dev/null || true

            su - postgres -c "psql -tc \"SELECT 1 FROM pg_database WHERE datname='$DB_NAME'\" | grep -q 1" 2>/dev/null || \
                su - postgres -c "psql -c \"CREATE DATABASE $DB_NAME OWNER $DB_USER;\"" 2>/dev/null || true

            su - postgres -c "psql -c \"GRANT ALL PRIVILEGES ON DATABASE $DB_NAME TO $DB_USER;\"" 2>/dev/null || true
            echo "PostgreSQL database '$DB_NAME' and user '$DB_USER' configured"
        else
            echo "Warning: PostgreSQL not found. Please install and configure manually."
        fi

        cat > "$APP_DIR/.env" << EOF
DATABASE_URL=postgresql+asyncpg://$DB_USER:$DB_PASS@localhost:5432/$DB_NAME
REDIS_URL=redis://localhost:6379/0
SECRET_KEY=$(openssl rand -hex 32)
CELERY_BROKER=redis://localhost:6379/0
CELERY_BACKEND=redis://localhost:6379/0
EOF
        chown printauto:printauto "$APP_DIR/.env"
        chmod 600 "$APP_DIR/.env"
        echo "Environment file created: $APP_DIR/.env"

        python3 -m venv "$VENV_DIR"
        "$VENV_DIR/bin/pip" install --no-cache-dir -r "$APP_DIR/requirements.txt"
        echo "Python virtual environment created at $VENV_DIR"

        "$VENV_DIR/bin/python" "$APP_DIR/generate_receipt_template.py"
        echo "Receipt template generated"

        bash "$APP_DIR/generate_certs.sh"
        echo "SSL certificates generated"

        cp "$APP_DIR/nginx.conf" /etc/nginx/sites-available/print-automation
        ln -sf /etc/nginx/sites-available/print-automation /etc/nginx/sites-enabled/
        if nginx -t 2>/dev/null; then
            systemctl restart nginx || true
            echo "Nginx configured and restarted"
        else
            echo "Warning: Nginx configuration test failed. Please check manually."
        fi

        systemctl enable redis-server 2>/dev/null || true
        systemctl start redis-server 2>/dev/null || true

        cat > /etc/systemd/system/print-automation-server.service << 'SERVICEEOF'
[Unit]
Description=Print Automation Server (FastAPI)
Documentation=https://print-automation.local
After=network.target postgresql.service redis-server.service
Wants=postgresql.service redis-server.service

[Service]
Type=simple
User=printauto
Group=printauto
WorkingDirectory=/opt/print-automation
Environment=PATH=/opt/print-automation/venv/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin
EnvironmentFile=/opt/print-automation/.env
ExecStart=/opt/print-automation/venv/bin/uvicorn main:app --host 0.0.0.0 --port 8000 --workers 2 --log-level info
Restart=always
RestartSec=5
LimitNOFILE=65536

[Install]
WantedBy=multi-user.target
SERVICEEOF

        cat > /etc/systemd/system/print-automation-celery.service << 'CELERYEOF'
[Unit]
Description=Print Automation Celery Worker
Documentation=https://print-automation.local
After=network.target redis-server.service
Wants=redis-server.service

[Service]
Type=simple
User=printauto
Group=printauto
WorkingDirectory=/opt/print-automation
Environment=PATH=/opt/print-automation/venv/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin
EnvironmentFile=/opt/print-automation/.env
ExecStart=/opt/print-automation/venv/bin/celery -A tasks worker --loglevel=info --concurrency=4 --max-tasks-per-child=100
Restart=always
RestartSec=5
LimitNOFILE=65536

[Install]
WantedBy=multi-user.target
CELERYEOF

        systemctl daemon-reload
        systemctl enable print-automation-server
        systemctl enable print-automation-celery
        systemctl start print-automation-server || echo "Warning: Server service failed to start"
        systemctl start print-automation-celery || echo "Warning: Celery service failed to start"
        echo "Systemd services created and started"

        echo ""
        echo "============================================"
        echo " Print Automation Server Installation Complete"
        echo "============================================"
        echo " Web Dashboard: https://print-automation.local"
        echo " API Endpoint:  https://print-automation.local/api/"
        echo " Database:      $DB_NAME"
        echo " Database User: $DB_USER"
        echo " Database Pass: $DB_PASS"
        echo " Config File:   $APP_DIR/.env"
        echo "============================================"
        echo "IMPORTANT: Save the database password above."
        echo "It is also stored in $APP_DIR/.env"
        echo "============================================"
        ;;
esac
