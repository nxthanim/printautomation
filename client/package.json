{
  "name": "print-automation-client",
  "version": "1.0.0",
  "description": "Print Automation Client",
  "main": "main.js",
  "scripts": {
    "start": "webpack --mode development && electron .",
    "webpack": "webpack --mode development",
    "dist": "webpack --mode production && electron-builder --win",
    "dist:dir": "webpack --mode production && electron-builder --win --dir"
  },
  "build": {
    "appId": "com.printautomation.client",
    "productName": "Print Automation Client",
    "directories": {
      "output": "dist_electron"
    },
    "files": [
      "dist/**/*",
      "main.js",
      "preload.js",
      "package.json",
      "config.ini",
      "src/utils/storage.js"
    ],
    "asarUnpack": [
      "dist/**",
      "preload.js"
    ],
    "extraResources": [],
    "win": {
      "signtoolOptions": {
        "certificateFile": "PrintAutomationClient.pfx",
        "certificatePassword": ""
      },
      "signAndEditExecutable": true,
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  },
  "devDependencies": {
    "@babel/core": "^7.23.0",
    "@babel/preset-env": "^7.23.0",
    "@babel/preset-react": "^7.22.0",
    "babel-loader": "^9.1.3",
    "css-loader": "^6.8.0",
    "electron": "^28.0.0",
    "electron-builder": "^26.15.3",
    "electron-packager": "^17.1.2",
    "html-webpack-plugin": "^5.5.0",
    "style-loader": "^3.3.0",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.0"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  }
}
